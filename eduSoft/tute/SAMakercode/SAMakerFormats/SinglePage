%  </BODY>
%  </HTML>

(EXPLANATION-FORMAT)
  <H1>Answer for Question RBEGIN $RpageNumber REND</H1>
  RBEGIN $Rexplanation REND
  RBEGIN The correct answer(s) are $RanswerTextREND
  <INPUT TYPE="submit" NAME="next" VALUE="Next Question">
  RBEGIN $RpagesRemaining more question(s) are left. REND
  <HR>
  CBEGIN $CquestionText CEND
  <HR>

(HINT-FORMAT)
  RBEGIN <H1> Hint for Question $RpageNumber</H1> <P> $RhintText <HR> REND
  CBEGIN $CquestionText CEND
  <HR>
  <INPUT TYPE="submit" NAME="skip" VALUE="Skip Question">
  CBEGIN $CexistsHint<INPUT TYPE="submit" NAME="hintFormatRBEGIN$RquestionIdREND" VALUE="Hint"> CEND

(QUESTION-FORMAT)
  CBEGIN$CquestionTextCEND
  <HR>
  <INPUT TYPE="submit" NAME="skip" VALUE="Skip Question">
  CBEGIN $CexistsHint<INPUT TYPE="submit" NAME="hintFormatRBEGIN$RquestionIdREND" VALUE="Hint"> CEND

(PAGE-FORMAT)
  <HTML>
  <HEAD>
  <TITLE>
  Question RBEGIN$RpageNumberREND
  </TITLE>
  </HEAD>
  <BODY>
  CBEGIN $CheaderText CEND
  CBEGIN
    <FORM METHOD="POST" ACTION="$Croot/marker$Cextension">
    RBEGIN<INPUT TYPE="hidden" NAME="hidden" VALUE="$RhiddenText">REND
    RBEGIN$RquestionsTextREND
    <BR>
    </FORM>
  CEND
  CBEGIN $CreturnText CEND
  CBEGIN $CfooterText CEND
  </BODY>
  </HTML>

(F-FORMAT)
 (DEFAULTANSWER)
  false
 (ACTUALTEXT)
  <H1>Question RBEGIN$RpageNumberREND True/False </H1>
  <HR>
  CBEGIN$CquestionTextCEND
  <BR><INPUT TYPE="submit" NAME="answerRBEGIN$RquestionIdREND" VALUE="true"> 
  <INPUT TYPE="submit" NAME="answerRBEGIN$RquestionIdREND" VALUE="false">

(T-FORMAT)
 (DEFAULTANSWER)
  true
 (ACTUALTEXT)
  <H1>Question RBEGIN$RpageNumberREND True/False </H1>
  <HR>
  CBEGIN$CquestionTextCEND
  <BR>
  <INPUT TYPE="submit" NAME="answerRBEGIN$RquestionIdREND" VALUE="true"> 
  <INPUT TYPE="submit" NAME="answerRBEGIN$RquestionIdREND" VALUE="false">

(MC-FORMAT)
 (VALUES)
  a,b,c,d,e,f,g,h,i,j,k,l,m,n,o,p,q,r,s,t,u,v,w
 (OPTION)
  CBEGIN<BR><INPUT TYPE="submit" 
                  NAME="answerRBEGIN$RquestionIdREND" 
                  VALUE="$CanswerValue"
            >$CanswerText
  CEND
 (ACTUALTEXT)
  <H1> Question RBEGIN$RpageNumberREND Multiple Choice </H1>
  <HR>
  CBEGIN$CquestionTextCEND
  CBEGIN$CanswerTextCEND

(MM-FORMAT)
 (OPTION)
  <OPTION> CBEGIN$CanswerTextCEND
 (ACTUALTEXT)
  <H1> Question RBEGIN$RpageNumberREND Many Choice </H1>
  CBEGIN$CquestionTextCEND
  <BR>
  <SELECT NAME="answerRBEGIN$RquestionIdREND" 
        SIZE=CBEGIN$CanswerSizeCEND MULTIPLE>
  CBEGIN$CanswerTextCEND
  </SELECT>
  <BR>
  <INPUT TYPE="submit" NAME="this" VALUE="Done"> 

(SA-FORMAT)
  CBEGIN$CquestionTextCEND
  <P>
  Put your answer here 
    <INPUT TYPE="text" NAME="answerRBEGIN$RquestionIdREND" VALUE="" SIZE=30>
  <INPUT TYPE="submit" NAME="this" VALUE="Done"> 

(EA-FORMAT)
 (ACTUALTEXT)
  <H1> Question RBEGIN$RpageNumberREND Exact Answer </H1>
  <HR>
  CBEGIN$CquestionTextCEND
  <P>
  Put your answer here 
    <INPUT TYPE="text" NAME="answerRBEGIN$RquestionIdREND" VALUE="" SIZE=30>
  <BR>
  <INPUT TYPE="submit" NAME="this" VALUE="Done"> 

(HEADER)

(FOOTER)

